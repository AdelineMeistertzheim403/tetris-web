datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

model User {
  id        Int      @id @default(autoincrement())
  pseudo    String   @unique
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  scores    Score[]
  versusAsPlayer1 VersusMatch[] @relation("VersusPlayer1")
  versusAsPlayer2 VersusMatch[] @relation("VersusPlayer2")
  versusAsWinner  VersusMatch[] @relation("VersusWinner")
  roguelikeVersusAsPlayer1 RoguelikeVersusMatch[] @relation("RoguelikeVersusPlayer1")
  roguelikeVersusAsPlayer2 RoguelikeVersusMatch[] @relation("RoguelikeVersusPlayer2")
  roguelikeVersusAsWinner  RoguelikeVersusMatch[] @relation("RoguelikeVersusWinner")
   roguelikeRuns RoguelikeRun[]
  puzzleAttempts PuzzleAttempt[]
  puzzleSolutions PuzzleSolution[]
  achievements UserAchievement[]
  achievementStats UserAchievementStats?
  settings UserSettings?
  brickfallSoloProgress BrickfallSoloProgress?
  tetromazeProgress TetromazeProgress?
  pixelProtocolProgress PixelProtocolProgress?
  brickfallSoloCustomLevels BrickfallSoloCustomLevel[]
  brickfallSoloPublishedLevels BrickfallSoloPublishedLevel[]
  brickfallSoloPublishedLevelLikes BrickfallSoloPublishedLevelLike[]
  tetromazeCustomLevels TetromazeCustomLevel[]
  tetromazePublishedLevels TetromazePublishedLevel[]
  tetromazePublishedLevelLikes TetromazePublishedLevelLike[]
  pixelProtocolCustomLevels PixelProtocolCustomLevel[]
  pixelProtocolWorldTemplates PixelProtocolWorldTemplate[]
  pixelProtocolPublishedLevels PixelProtocolPublishedLevel[]
  pixelProtocolPublishedLevelLikes PixelProtocolPublishedLevelLike[]
  botPlayerProfile BotPlayerProfile?
  createdAt DateTime @default(now())
}

model PixelProtocolLevel {
  id         String   @id
  name       String
  world      Int
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  definition Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([world, sortOrder])
  @@index([active])
}

model UserSettings {
  userId    Int      @id
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model BotPlayerProfile {
  userId Int @id
  totalMatches Int @default(0)

  avgStackHeight Float @default(0)
  avgHoles Float @default(0)
  avgCombo Float @default(0)
  tetrisRate Float @default(0)
  aggressionScore Float @default(0)
  defensiveScore Float @default(0)
  panicRate Float @default(0)
  leftBias Float @default(0)
  noHoldRate Float @default(0)

  matchesVsRookie Int @default(0)
  matchesVsBalanced Int @default(0)
  matchesVsApex Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Score {
  id        Int      @id @default(autoincrement())
  value     Int
  level     Int
  lines     Int
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  createdAt DateTime @default(now())
  mode      GameMode @default(CLASSIQUE)
}

model VersusMatch {
  id             Int      @id @default(autoincrement())
  matchId        String?
  player1Id      Int?
  player1Pseudo  String
  player1Score   Int
  player1Lines   Int
  player2Id      Int?
  player2Pseudo  String
  player2Score   Int
  player2Lines   Int
  winnerId       Int?
  winnerPseudo   String?
  createdAt      DateTime @default(now())

  player1 User? @relation("VersusPlayer1", fields: [player1Id], references: [id])
  player2 User? @relation("VersusPlayer2", fields: [player2Id], references: [id])
  winner  User? @relation("VersusWinner", fields: [winnerId], references: [id])
}

model RoguelikeVersusMatch {
  id             Int      @id @default(autoincrement())
  matchId        String?
  player1Id      Int?
  player1Pseudo  String
  player1Score   Int
  player1Lines   Int
  player2Id      Int?
  player2Pseudo  String
  player2Score   Int
  player2Lines   Int
  winnerId       Int?
  winnerPseudo   String?
  createdAt      DateTime @default(now())

  player1 User? @relation("RoguelikeVersusPlayer1", fields: [player1Id], references: [id])
  player2 User? @relation("RoguelikeVersusPlayer2", fields: [player2Id], references: [id])
  winner  User? @relation("RoguelikeVersusWinner", fields: [winnerId], references: [id])
}

model RoguelikeRun {
  id                Int      @id @default(autoincrement())
  userId            Int

  seed              String
  state             Json
  
  score             BigInt
  lines             Int
  level             Int

  perks             Json     // tableau d’ids de perks
  mutations         Json     // array of mutation ids and stacks
  bombs             Int
  timeFreezeCharges Int
  chaosMode         Boolean

  gravityMultiplier Float
  scoreMultiplier   Float

  status            RunStatus
  createdAt         DateTime @default(now())
  endedAt           DateTime?

  user              User     @relation(fields: [userId], references: [id])
}

model Achievement {
  id          String   @id
  name        String
  description String
  icon        String
  category    String   // run, combat, bomb, chaos, mastery…
  hidden      Boolean  @default(false)
  users       UserAchievement[]
}

model UserAchievement {
  userId        Int
  achievementId String
  unlockedAt    DateTime @default(now())

  user          User        @relation(fields: [userId], references: [id])
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  @@id([userId, achievementId])
}

model UserAchievementStats {
  userId               Int      @id
  loginDays            Json     @default("[]")
  tetrobotProgression  Json     @default("{}")
  tetrobotXpLedger     Json     @default("{}")
  tetrobotAffinityLedger Json   @default("{}")
  playerLongTermMemory Json     @default("{}")
  tetrobotMemories     Json     @default("{}")
  lastTetrobotLevelUp  Json?
  activeTetrobotChallenge Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id])
}

model BrickfallSoloProgress {
  userId       Int      @id
  highestLevel Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
}

model TetromazeProgress {
  userId       Int      @id
  highestLevel Int      @default(1)
  currentLevel Int      @default(1)
  levelScores  Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
}

model PixelProtocolProgress {
  userId       Int      @id
  highestLevel Int      @default(1)
  currentLevel Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
}

model BrickfallSoloCustomLevel {
  id         Int      @id @default(autoincrement())
  userId     Int
  levelId    String
  definition Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, levelId])
  @@index([userId, updatedAt])
}

model BrickfallSoloPublishedLevel {
  id         Int      @id @default(autoincrement())
  userId     Int
  levelId    String
  name       String
  playCount  Int      @default(0)
  definition Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
  likes      BrickfallSoloPublishedLevelLike[]

  @@unique([userId, levelId])
  @@index([updatedAt])
}

model BrickfallSoloPublishedLevelLike {
  id               Int      @id @default(autoincrement())
  publishedLevelId Int
  userId           Int
  createdAt        DateTime @default(now())

  publishedLevel   BrickfallSoloPublishedLevel @relation(fields: [publishedLevelId], references: [id])
  user             User                        @relation(fields: [userId], references: [id])

  @@unique([publishedLevelId, userId])
  @@index([userId, createdAt])
}

model TetromazeCustomLevel {
  id         Int      @id @default(autoincrement())
  userId     Int
  levelId    String
  definition Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, levelId])
  @@index([userId, updatedAt])
}

model TetromazePublishedLevel {
  id         Int      @id @default(autoincrement())
  userId     Int
  levelId    String
  name       String
  playCount  Int      @default(0)
  definition Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
  likes      TetromazePublishedLevelLike[]

  @@unique([userId, levelId])
  @@index([updatedAt])
}

model TetromazePublishedLevelLike {
  id               Int      @id @default(autoincrement())
  publishedLevelId Int
  userId           Int
  createdAt        DateTime @default(now())

  publishedLevel   TetromazePublishedLevel @relation(fields: [publishedLevelId], references: [id])
  user             User                    @relation(fields: [userId], references: [id])

  @@unique([publishedLevelId, userId])
  @@index([userId, createdAt])
}

model PixelProtocolCustomLevel {
  id         Int      @id @default(autoincrement())
  userId     Int
  levelId    String
  definition Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, levelId])
  @@index([userId, updatedAt])
}

model PixelProtocolWorldTemplate {
  id         Int      @id @default(autoincrement())
  userId     Int
  templateId String
  definition Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, templateId])
  @@index([userId, updatedAt])
}

model PixelProtocolPublishedLevel {
  id         Int      @id @default(autoincrement())
  userId     Int
  levelId    String
  name       String
  world      Int
  playCount  Int      @default(0)
  definition Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
  likes      PixelProtocolPublishedLevelLike[]

  @@unique([userId, levelId])
  @@index([updatedAt])
}

model PixelProtocolPublishedLevelLike {
  id               Int      @id @default(autoincrement())
  publishedLevelId Int
  userId           Int
  createdAt        DateTime @default(now())

  publishedLevel   PixelProtocolPublishedLevel @relation(fields: [publishedLevelId], references: [id])
  user             User                       @relation(fields: [userId], references: [id])

  @@unique([publishedLevelId, userId])
  @@index([userId, createdAt])
}

enum RunStatus {
  IN_PROGRESS
  FINISHED
  ABANDONED
}

enum GameMode {
  CLASSIQUE
  SPRINT
  VERSUS
  ROGUELIKE_VERSUS
}

enum UserRole {
  USER
  ADMIN
}

model Puzzle {
  id          String   @id
  name        String
  description String
  difficulty  String   @default("normal")
  definition  Json
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attempts PuzzleAttempt[]
  solutions PuzzleSolution[]
}

model PuzzleAttempt {
  id              Int      @id @default(autoincrement())
  puzzleId        String
  userId          Int
  success         Boolean
  movesUsed       Int
  linesCleared    Int
  piecesPlaced    Int
  holdUsed        Boolean
  efficiencyScore Int
  optimal         Boolean  @default(false)
  createdAt       DateTime @default(now())

  puzzle Puzzle @relation(fields: [puzzleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId, puzzleId])
}

model PuzzleSolution {
  id        Int      @id @default(autoincrement())
  puzzleId  String
  userId    Int
  movesUsed Int
  data      Json
  optimal   Boolean  @default(false)
  createdAt DateTime @default(now())

  puzzle Puzzle @relation(fields: [puzzleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId, puzzleId])
}
