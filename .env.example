# ~/tetris-web/.env  ← utilisé par Docker Compose
BACKEND_PORT=8085
BACKEND_INTERNAL_PORT=8080
POSTGRES_USER=tetris_user
POSTGRES_PASSWORD=tetris_pass
POSTGRES_DB=tetris_db

# ~/tetris-web/backend/.env  ← monté dans le conteneur backend
DATABASE_URL=postgresql://tetris_user:tetris_pass@tetris-db:5432/tetris_db?schema=public
JWT_SECRET=super_secret_tetris_key
PORT=8080
NODE_ENV=production

# Admin seed (backend/prisma/seed.ts)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me
ADMIN_PSEUDO=Admin
# Force reseed Pixel Protocol levels
SEED_PIXEL_LEVELS=false
